# Copy this file to .env.local and fill in real values.
# None of these are required for the site to build and run in development —
# the relevant features degrade gracefully when a value is missing.

# The canonical, public base URL of the site (no trailing slash).
# Used for canonical tags, sitemap, robots and Open Graph URLs.
NEXT_PUBLIC_SITE_URL=https://www.littlejoestreeservices.co.uk

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# When empty, GA4 is not loaded at all (no dummy/duplicate tracking).
NEXT_PUBLIC_GA4_ID=

# Google Search Console HTML-tag verification token (the content="..." value).
# Optional — leave blank if verifying by DNS or file upload instead.
NEXT_PUBLIC_GSC_VERIFICATION=

# Contact form delivery for the STATIC site — Web3Forms (https://web3forms.com).
# Create a free access key (the destination email is configured there) and paste
# it here. Must be NEXT_PUBLIC_* because the static form posts from the browser.
# When empty, the form asks visitors to call instead of failing silently.
NEXT_PUBLIC_WEB3FORMS_KEY=
